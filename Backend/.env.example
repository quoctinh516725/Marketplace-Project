# Database (SQL Server) - Use mssql for Docker, localhost for local dev
DATABASE_URL=sqlserver://mssql:1433;database=MarketplaceDB;user=sa;password=YourStrong!Passw0rd;encrypt=false;trustServerCertificate=true

# Redis (Upstash)
REDIS_URL=rediss://default:your-redis-url@host:port

# Elasticsearch - Use elasticsearch for Docker, localhost for local dev
ES_URL=http://elasticsearch:9200

# App
PORT=8080
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7
JWT_ACCESS_EXPIRES_IN=60

# Cloudinary
CLOUDINARY_URL=cloudinary://your-cloud-name:your-api-key:your-api-secret@your-cloud

# GHN (Shipping)
GHN_TOKEN=your-ghn-token
GHN_SHOP_ID=your-shop-id
GHN_API_URL=https://online-gateway.ghn.vn/shiip/public-api

# VNPay
VNP_TMNCODE=your-tmn-code
VNP_HASHSECRET=your-hash-secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:8080/api/payments/payment-return

# Email
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# OAuth
OAUTH_CLIENT_ID=your-google-client-id